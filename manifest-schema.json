{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Hypercube Neo Manifest V4",
    "description": "Declarative configuration for the Hypercube Neo Spatial Computing Engine",
    "type": "object",
    "required": [
        "name",
        "engine",
        "config"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "version": {
            "type": "string"
        },
        "engine": {
            "type": "object",
            "required": [
                "faces",
                "rules"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                },
                "faces": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "name",
                            "type"
                        ],
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "scalar",
                                    "vector",
                                    "mask",
                                    "factor",
                                    "tensor"
                                ]
                            },
                            "isSynchronized": {
                                "type": "boolean"
                            },
                            "isPersistent": {
                                "type": "boolean"
                            },
                            "isReadOnly": {
                                "type": "boolean"
                            },
                            "isPingPong": {
                                "type": "boolean"
                            }
                        }
                    }
                },
                "rules": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "type"
                        ],
                        "properties": {
                            "type": {
                                "type": "string"
                            },
                            "method": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            },
                            "params": {
                                "type": "object",
                                "additionalProperties": true
                            }
                        }
                    }
                },
                "requirements": {
                    "type": "object",
                    "properties": {
                        "ghostCells": {
                            "type": "integer"
                        },
                        "pingPong": {
                            "type": "boolean"
                        }
                    }
                },
                "parameters": {
                    "type": "object"
                },
                "outputs": {
                    "type": "array"
                }
            }
        },
        "config": {
            "type": "object",
            "required": [
                "dimensions",
                "chunks"
            ],
            "properties": {
                "dimensions": {
                    "type": "object",
                    "required": [
                        "nx",
                        "ny"
                    ],
                    "properties": {
                        "nx": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "ny": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "nz": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1
                        }
                    }
                },
                "chunks": {
                    "type": "object",
                    "required": [
                        "x",
                        "y"
                    ],
                    "properties": {
                        "x": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "y": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                },
                "params": {
                    "type": "object",
                    "additionalProperties": true
                },
                "boundaries": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "role": {
                                "type": "string"
                            }
                        }
                    }
                },
                "mode": {
                    "type": "string",
                    "enum": [
                        "cpu",
                        "gpu",
                        "auto"
                    ],
                    "default": "auto"
                },
                "executionMode": {
                    "type": "string",
                    "enum": [
                        "serial",
                        "parallel"
                    ],
                    "default": "parallel"
                },
                "objects": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "id",
                            "type",
                            "position"
                        ],
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "rect",
                                    "circle",
                                    "polygon"
                                ]
                            },
                            "position": {
                                "type": "object",
                                "properties": {
                                    "x": {
                                        "type": "number"
                                    },
                                    "y": {
                                        "type": "number"
                                    }
                                }
                            },
                            "dimensions": {
                                "type": "object",
                                "properties": {
                                    "w": {
                                        "type": "number"
                                    },
                                    "h": {
                                        "type": "number"
                                    }
                                }
                            },
                            "points": {
                                "type": "array"
                            },
                            "properties": {
                                "type": "object",
                                "additionalProperties": true
                            },
                            "rasterMode": {
                                "type": "string",
                                "enum": [
                                    "replace",
                                    "add",
                                    "multiply"
                                ]
                            },
                            "isVisible": {
                                "type": "boolean"
                            },
                            "isBaked": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            }
        }
    }
}