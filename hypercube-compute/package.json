{
  "name": "hypercube-compute",
  "version": "4.0.0-alpha.2",
  "description": "A high-performance O(1) tensor-based compute engine for Web and Node.js environments.",
  "main": "hypercube-neo/dist/index.js",
  "module": "hypercube-neo/dist/index.mjs",
  "types": "hypercube-neo/dist/index.d.ts",
  "scripts": {
    "build": "tsup hypercube-neo/HypercubeNeo.ts --format cjs,esm --dts --clean",
    "dev": "tsup hypercube-neo/HypercubeNeo.ts --format cjs,esm --dts --watch",
    "test": "vitest run hypercube-neo/tests",
    "test:watch": "vitest hypercube-neo/tests",
    "showcase": "vite --config hypercube-neo/vite.config.ts",
    "neo:showcase": "vite --config hypercube-neo/vite.config.ts"
  },
  "keywords": [
    "tensor",
    "compute",
    "O(1)",
    "engine",
    "physics",
    "webassembly",
    "web-workers",
    "lattice-boltzmann"
  ],
  "author": "Helron1977",
  "license": "MIT",
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}