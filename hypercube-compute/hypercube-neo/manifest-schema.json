{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Hypercube Neo Manifest",
    "description": "Declarative configuration for the Hypercube Neo Spatial Computing Engine",
    "type": "object",
    "required": [
        "engine",
        "config",
        "visualProfile"
    ],
    "properties": {
        "engine": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "neo-aero-v1",
                        "neo-ocean-v1",
                        "neo-thermal-v3",
                        "neo-sdf"
                    ]
                },
                "params": {
                    "type": "object",
                    "additionalProperties": true
                },
                "faces": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "name",
                            "isPingPong"
                        ],
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "isPingPong": {
                                "type": "boolean"
                            },
                            "isSynchronized": {
                                "type": "boolean",
                                "default": true
                            }
                        }
                    }
                }
            }
        },
        "config": {
            "type": "object",
            "required": [
                "dimensions",
                "chunks"
            ],
            "properties": {
                "mode": {
                    "type": "string",
                    "enum": [
                        "cpu",
                        "gpu",
                        "auto"
                    ],
                    "default": "auto"
                },
                "dimensions": {
                    "type": "object",
                    "required": [
                        "nx",
                        "ny"
                    ],
                    "properties": {
                        "nx": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "ny": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "nz": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1
                        }
                    }
                },
                "chunks": {
                    "type": "object",
                    "required": [
                        "x",
                        "y"
                    ],
                    "properties": {
                        "x": {
                            "type": "integer"
                        },
                        "y": {
                            "type": "integer"
                        }
                    }
                }
            }
        },
        "visualProfile": {
            "type": "object",
            "properties": {
                "colormap": {
                    "type": "string"
                },
                "range": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    },
                    "minItems": 2,
                    "maxItems": 2
                }
            }
        }
    }
}